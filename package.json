{
  "name": "conesoft",
  "version": "1.10.0",
  "description": "Local-first desktop app for file conversion and media tooling. Convert images, video, audio, and documents entirely on-device. No uploads, no cloud.",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dev:all": "concurrently -n vite,electron -c cyan,yellow \"vite\" \"electron .\"",
    "prep:browsers": "node scripts/install-browser.mjs",
    "package": "tsc --noEmit && node scripts/install-browser.mjs && vite build && electron-builder",
    "package:mac": "tsc --noEmit && node scripts/install-browser.mjs && vite build && electron-rebuild -f -w sharp && electron-builder --mac",
    "package:win": "tsc --noEmit && node scripts/install-browser.mjs && vite build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps && node node_modules/ffmpeg-static/install.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "file-converter",
    "image-converter",
    "video-converter",
    "media-tools",
    "electron",
    "desktop-app",
    "local-first",
    "image-editor",
    "favicon-generator",
    "svg-editor"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.sanodzegg.conesoft",
    "productName": "Conesoft",
    "protocols": {
      "name": "Conesoft",
      "schemes": [
        "conesoft"
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "appx"
      ]
    },
    "appx": {
      "identityName": "Conlab.ConeLab",
      "publisher": "CN=2F9FE4F3-C390-4CF8-9EDF-67E5029D73CC",
      "publisherDisplayName": "GS Works",
      "applicationId": "ConeLab",
      "displayName": "Conesoft Tools",
      "backgroundColor": "#1a1a1a"
    },
    "files": [
      "dist/**",
      "electron/**",
      "main.js",
      "node_modules/**",
      "!node_modules/.cache/**",
      "!node_modules/.vite/**"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "ms-playwright",
        "to": "ms-playwright"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "**/node_modules/detect-libc/**/*",
      "**/node_modules/semver/**/*",
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/heic-convert/**/*",
      "**/node_modules/heic-decode/**/*",
      "**/node_modules/jpeg-js/**/*",
      "**/node_modules/pngjs/**/*",
      "**/node_modules/libheif-js/**/*"
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "nativeRebuilder": "legacy"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jszip": "^3.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@img/sharp-win32-x64": "0.34.5",
    "@imgly/background-removal": "^1.7.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-virtual": "^3.13.24",
    "chrome-launcher": "^1.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "core-util-is": "1.0.2",
    "docx": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "heic-convert": "^2.1.0",
    "immediate": "3.0.6",
    "isarray": "1.0.0",
    "jszip": "^3.10.1",
    "lie": "^3.3.0",
    "lighthouse": "^13.4.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "pdfkit": "^0.18.0",
    "playwright-core": "^1.58.2",
    "process-nextick-args": "2.0.1",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "readable-stream": "^4.7.0",
    "safe-buffer": "5.1.2",
    "setimmediate": "^1.0.5",
    "shadcn": "^4.0.8",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  }
}
